#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing hbctool 0.1.5...${NC}"

echo -e "${YELLOW}Downloading hbctool...${NC}"
curl -sL -o $TMPDIR/hbctool-0.1.5-96-py3-none-any.whl "https://github.com/Kirlif/HBC-Tool/releases/download/96/hbctool-0.1.5-96-py3-none-any.whl" || {
    echo -e "${RED}Error: Failed to download hbctool.${NC}"
    exit 1
}

echo -e "${YELLOW}Installing hbctool...${NC}"
pip install --quiet --force-reinstall $TMPDIR/hbctool-0.1.5-96-py3-none-any.whl || {
    echo -e "${RED}Error: Failed to install hbctool.${NC}"
    exit 1
}

rm -f $TMPDIR/hbctool-0.1.5-96-py3-none-any.whl

echo -e "${GREEN}hbctool installed successfully!${NC}"
exit 0
